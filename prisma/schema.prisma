// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model User {
  id                     String   @id @default(uuid())
  firstName              String
  lastName               String?
  email                  String   @unique
  password               String
  role                   Role     @default(USER)
  city                   String?
  street                 String?
  dateOfBirth            DateTime?
  gender                 String?
  profilePhoto           String?
  profilePublicId        String?
  reset_token            String?  @unique
  reset_token_expiration DateTime?
  vehicle                   vehicle[] 
  bookings               Booking[]
}


model vehicle {
  id            String            @id @default(uuid())
  userID        String
  user          User              @relation(fields: [userID], references: [id])
  brand         String
  carName       String
  model         String
  seat          String
  mileage       String
  engine        EngineType
  transmission  TransmissionType
  price         String
  carType       CarType
  description   String
  imageUrl      String?
  imagePublicId String?
  views         Int               @default(0)
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt
  bookings      Booking[]  
}

model Booking {
  id              String         @id @default(uuid())
  userId          String
  user            User           @relation(fields: [userId], references: [id])
  vehicleId           String
  vehicle             vehicle         @relation(fields: [vehicleId], references: [id])
  tripType        TripType
  departurePoint  String         
  arrivalPoint    String
  status          BookingStatus  @default(BOOKED)
  totalPrice      Float
  days            Int
  paymentIntentId String?
  rentalDate     DateTime
  createdAt       DateTime       @default(now())
  payment   Payment? @relation("BookingPayment")
  invoice   Invoice? @relation("BookingInvoice")
}

model Payment {
  id         String   @id @default(uuid())
  bookingId  String   @unique
  booking    Booking  @relation("BookingPayment", fields: [bookingId], references: [id])
  stripePaymentId String
  amount     Float
  status     PaymentStatus @default(PAID)
  createdAt  DateTime @default(now())
  invoice    Invoice? @relation("PaymentInvoice")
}


model Invoice {
  id          String   @id @default(uuid())
  bookingId   String   @unique
  paymentId   String   @unique
  booking     Booking  @relation("BookingInvoice", fields: [bookingId], references: [id])
  payment     Payment  @relation("PaymentInvoice", fields: [paymentId], references: [id])
  invoiceNumber String
  invoiceUrl    String?
  paymentStatus PaymentStatus
  createdAt     DateTime @default(now())
}

model Event {
  id        String   @id @default(uuid())
  title     String
  start     DateTime
  color     String?
  createdAt DateTime @default(now())
}

enum Role {
  ADMIN
  USER
}

enum EngineType {
  PETROL
  DIESEL
  ELECTRIC
  HYBRID
}

enum TransmissionType {
  MANUAL
  AUTOMATIC
}

enum CarType {
  LUXURYCAR
  VINTAGECAR
  FAMILYCAR
  OFFROADCAR
}

enum BookingStatus {
  BOOKED
}

enum TripType {
  ONEWAY
  TWOWAY
}

enum PaymentStatus {
  PAID
  FAILED
}